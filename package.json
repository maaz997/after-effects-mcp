{
  "name": "after-effects-mcp",
  "version": "1.0.0",
  "description": "MCP server for Adobe After Effects",
  "author": "maaz997",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/maaz997/after-effects-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/maaz997/after-effects-mcp/issues"
  },
  "homepage": "https://github.com/maaz997/after-effects-mcp#readme",
  "license": "MIT",
  "main": "build/index.js",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --packages=external --platform=node --format=esm --target=es2022 --outfile=build/index.js && copyfiles -u 1 \"src/scripts/**/*\" build",
    "start": "node build/index.js",
    "test": "esbuild src/validate-bridge-command.test.ts --bundle --platform=node --format=esm --target=es2022 --outfile=build/validate-bridge-command.test.mjs && node --test build/validate-bridge-command.test.mjs",
    "install-bridge": "node install-bridge.js",
    "postinstall": "yarn build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.2"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "copyfiles": "^2.4.1",
    "esbuild": "^0.25.0",
    "typescript": "^5.2.2"
  }
}
